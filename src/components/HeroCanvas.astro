---
// HeroCanvas.astro - Three.js 3D floating DevOps icons 
---

<canvas id="hero-canvas" width="400" height="400" style="width:100%;max-width:400px;height:400px;"></canvas>

<script>
  import * as THREE from 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.module.min.js';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 1000);
    camera.position.z = 5;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(400, 400);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // DevOps icon URLs
    const icons = [
      { name: 'docker', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg', speed: 0.3, radius: 2.8, offset: 0 },
      { name: 'kubernetes', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kubernetes/kubernetes-plain.svg', speed: 0.4, radius: 2.5, offset: Math.PI * 0.25 },
      { name: 'aws', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/amazonwebservices/amazonwebservices-plain-wordmark.svg', speed: 0.5, radius: 3.0, offset: Math.PI * 0.5 },
      { name: 'terraform', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/terraform/terraform-original.svg', speed: 0.35, radius: 2.6, offset: Math.PI * 0.75 },
      { name: 'jenkins', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/jenkins/jenkins-original.svg', speed: 0.6, radius: 2.4, offset: Math.PI },
      { name: 'ansible', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ansible/ansible-original.svg', speed: 0.45, radius: 2.9, offset: Math.PI * 1.25 },
      { name: 'github', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg', speed: 0.55, radius: 2.3, offset: Math.PI * 1.5 },
      { name: 'linux', url: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/linux/linux-original.svg', speed: 0.8, radius: 2.7, offset: Math.PI * 1.75 },
    ];

    const textureLoader = new THREE.TextureLoader();
    const iconMeshes: { mesh: THREE.Mesh; speed: number; radius: number; offset: number; bobOffset: number }[] = [];

    icons.forEach((icon) => {
      textureLoader.load(icon.url, (texture) => {
        const geometry = new THREE.PlaneGeometry(0.6, 0.6);
        const material = new THREE.MeshBasicMaterial({
          map: texture,
          transparent: true,
          side: THREE.DoubleSide,
        });
        const mesh = new THREE.Mesh(geometry, material);
        scene.add(mesh);
        iconMeshes.push({
          mesh,
          speed: icon.speed,
          radius: icon.radius,
          offset: icon.offset,
          bobOffset: Math.random() * Math.PI * 2,
        });
      });
    });

    // Particles
    const particleGeometry = new THREE.BufferGeometry();
    const particleCount = 50;
    const positions = new Float32Array(particleCount * 3);
    for (let i = 0; i < particleCount; i++) {
      positions[i * 3] = (Math.random() - 0.5) * 8;
      positions[i * 3 + 1] = (Math.random() - 0.5) * 8;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 4;
    }
    particleGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    const particleMaterial = new THREE.PointsMaterial({ color: 0x00ff94, size: 0.03, transparent: true, opacity: 0.6 });
    const particles = new THREE.Points(particleGeometry, particleMaterial);
    scene.add(particles);

    let mouseX = 0;
    let mouseY = 0;

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
      mouseY = -((e.clientY - rect.top) / rect.height - 0.5) * 2;
    });

    const clock = new THREE.Clock();

    function animate() {
      requestAnimationFrame(animate);
      const t = clock.getElapsedTime();

      iconMeshes.forEach((item) => {
        const angle = t * item.speed + item.offset;
        item.mesh.position.x = Math.cos(angle) * item.radius * 0.5;
        item.mesh.position.z = Math.sin(angle) * item.radius * 0.3;
        item.mesh.position.y = Math.sin(t * 0.8 + item.bobOffset) * 0.3;
        item.mesh.lookAt(camera.position);
      });

      // Mouse tilt
      scene.rotation.y += (mouseX * 0.3 - scene.rotation.y) * 0.05;
      scene.rotation.x += (mouseY * 0.2 - scene.rotation.x) * 0.05;

      // Animate particles
      particles.rotation.y = t * 0.02;

      renderer.render(scene, camera);
    }

    animate();
  }
</script>
