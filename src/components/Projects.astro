---
// Projects.astro - Project cards grid with tilt 

const projects = [
  {
    tag: 'Kubernetes',
    title: 'K8s Auto-Scaler',
    description: 'Automated horizontal pod autoscaling based on custom Prometheus metrics. Includes alerting rules, Grafana dashboards, and HPA configurations for production workloads.',
    tech: ['Kubernetes', 'Prometheus', 'Grafana', 'Helm'],
    github: 'https://github.com/',
    live: '#',
  },
  {
    tag: 'IaC',
    title: 'AWS Infra with Terraform',
    description: 'Complete AWS infrastructure provisioned using Terraform modules — VPC, ECS Fargate, RDS, ALB, and S3 with remote state management and automated drift detection.',
    tech: ['AWS', 'Terraform', 'S3', 'CloudWatch'],
    github: 'https://github.com/',
    live: '#',
  },
  {
    tag: 'CI/CD',
    title: 'CI/CD Pipeline Builder',
    description: 'Multi-stage Jenkins pipeline with Docker-based build agents, automated testing, artifact publishing, and blue-green deployments to ECS with rollback support.',
    tech: ['Jenkins', 'Docker', 'AWS ECS', 'Bash'],
    github: 'https://github.com/',
    live: '#',
  },
  {
    tag: 'GitOps',
    title: 'GitOps Deployment Flow',
    description: 'End-to-end GitOps workflow using ArgoCD and GitLab CI. Application manifests are versioned in Git, with automated sync, health checks, and progressive rollouts.',
    tech: ['ArgoCD', 'GitLab CI', 'Kubernetes', 'Kustomize'],
    github: 'https://github.com/',
    live: '#',
  },
];
---

<section class="section" id="projects">
  <p class="section-label">// my work</p>
  <h2 class="section-heading">Projects That Ship</h2>

  <div class="projects-grid">
    {projects.map((project) => (
      <div class="project-card" data-tilt>
        <span class="project-tag">{project.tag}</span>
        <h3 class="project-title">{project.title}</h3>
        <p class="project-desc">{project.description}</p>
        <div class="project-stack">
          {project.tech.map(t => <span class="stack-pill">{t}</span>)}
        </div>
        <div class="project-links">
          <a href={project.github} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <a href={project.live} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Live
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // Card entrance animation with IntersectionObserver
  const cards = document.querySelectorAll('.project-card');
  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add('visible');
        }, i * 100);
        cardObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  cards.forEach(card => cardObserver.observe(card));

  // Vanilla tilt effect
  cards.forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const el = card as HTMLElement;
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -5;
      const rotateY = ((x - centerX) / centerX) * 5;
      el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });

    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale(1)';
    });
  });
</script>
